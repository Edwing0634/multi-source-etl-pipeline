# SQL Server
DB_SERVER=localhost
DB_NAME=etl_staging
DB_USER=
DB_PASSWORD=
DB_DRIVER=ODBC Driver 17 for SQL Server

# SFTP
SFTP_HOST=sftp.yourserver.com
SFTP_PORT=22
SFTP_USER=etl_user
SFTP_PASSWORD=
SFTP_KEY_PATH=
SFTP_REMOTE_DIR=/uploads/

# REST APIs
API_BASE_URL=https://api.yourservice.com
API_KEY=your-api-key
API_TIMEOUT=30

# AS400 / OPENQUERY linked server
AS400_LINKED_SERVER=AS400_SERVER
AS400_LIBRARY=YOURLIB

# Pipeline
LOG_LEVEL=INFO
BATCH_SIZE=1000
